    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@pristav/shared": "workspace:*",
    "better-sqlite3": "^9.6.0",
    "drizzle-orm": "^0.30.10",
    "fastify": "^4.27.0",
    "fastify-plugin": "^4.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.14.0",
    "drizzle-kit": "^0.21.4",
