# ─── Required ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_secure_random_string_min_64chars
JWT_REFRESH_SECRET=replace_with_another_secure_random_string

# ─── CORS (comma-separated list of allowed origins) ───────────────────────────
ALLOWED_ORIGINS=https://pristav-radosti.cz,https://www.pristav-radosti.cz

# ─── Frontend ─────────────────────────────────────────────────────────────────
# URL exposed to browsers (usually nginx public URL)
NEXT_PUBLIC_API_URL=https://pristav-radosti.cz/api

# ─── Email (Nodemailer SMTP) ──────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@pristav-radosti.cz
SMTP_PASS=

# ─── SMS (FAYN) ───────────────────────────────────────────────────────────────
FAYN_API_KEY=

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:admin@pristav-radosti.cz
# Example keys (DO NOT use in production — generate your own with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=BIb6q6_kpiixh5NSLgQUcIAYhzBmFHXWLNdozgxtWMF4yw4iqDfu7ApIQ4WTFI6SZLy2YVo4I3Byj6ZkfPIj-9c
VAPID_PRIVATE_KEY=E0SO-d0liwq_G0iHI_YWmqh4WaTZzdHlRpZoXP8gcho

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=/app/data/pristav.db
# For backup script:
BACKUP_DIR=/app/data/backups
BACKUP_KEEP_DAYS=14

# ─── JWT expiry ───────────────────────────────────────────────────────────────
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── FIO Bank integration ─────────────────────────────────────────────────────
FIO_API_KEY=

# ─── Reminder scheduler ───────────────────────────────────────────────────────
# Hours before appointment to send reminders (default: 24)
REMINDER_HOURS=24
