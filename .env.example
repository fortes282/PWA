# Backend
PORT=3001
NODE_ENV=development
DATABASE_PATH=/app/data/pristav.db

# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Email (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pristav-radosti.cz

# SMS (FAYN)
FAYN_API_KEY=
FAYN_SENDER=

# Web Push (VAPID)
VAPID_SUBJECT=mailto:admin@pristav-radosti.cz
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# FIO Bank
FIO_API_TOKEN=
